<Window x:Class="MovieDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MovieDemo" 
        mc:Ignorable="d"
        Title="电影爬虫工具" Height="600" Width="900">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 第一行：URL输入和操作按钮 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBox Text="{Binding SiteUrl}" Width="500" FontSize="14" Margin="0,0,10,0" 
                     VerticalAlignment="Center"/>
            <Button Command="{Binding StartCheckCommand}" 
                    Content="检测网站" 
                    Width="100" Height="30"
                    Margin="0,0,10,0"/>
            <Button Command="{Binding StartCrawlCommand}" 
                    Content="获取列表" 
                    Width="100" Height="30"
                    Margin="0,0,10,0"/>
            <Button Command="{Binding StopCrawlCommand}" 
                    Content="停止" 
                    Width="80" Height="30"
                    Background="LightCoral"/>
        </StackPanel>

        <!-- 第二行：状态显示 -->
        <Border Grid.Row="1" Background="#F0F0F0" CornerRadius="5" Padding="10" Margin="0,0,0,10">
            <TextBlock Text="{Binding StatusText}" FontSize="14" />
        </Border>

        <!-- 第三行：XPath和选择器配置 -->
        <Expander Grid.Row="2" Header="高级设置" IsExpanded="False" Margin="0,0,0,10">
            <StackPanel Margin="10">
                <TextBlock Text="XPath表达式：" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox Text="{Binding XPath}" Height="60" TextWrapping="Wrap" 
                         Margin="0,0,0,10"/>
                <TextBlock Text="等待选择器：" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox Text="{Binding WaitSelector}" Height="30" Margin="0,0,0,10"/>
                <TextBlock Text="示例：" Foreground="Gray" FontSize="12"/>
                <TextBlock Text="XPath: //div[@class='movie-item']/h3/a" Foreground="Gray" FontSize="12"/>
                <TextBlock Text="等待选择器: .movie-item 或 #movie-list" Foreground="Gray" FontSize="12"/>
            </StackPanel>
        </Expander>

        <!-- 第四行：电影列表显示 -->
        <Grid Grid.Row="3" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ListBox Grid.Column="0" ItemsSource="{Binding MovieList}" 
                     SelectionMode="Extended">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" Margin="5" FontSize="13"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Top">
                <Button Content="导出列表" Command="{Binding ExportCommand}" 
                        Width="100" Height="30" Margin="0,0,0,10"/>
                <Button Content="清空列表" Command="{Binding ClearListCommand}" 
                        Width="100" Height="30"/>
            </StackPanel>
        </Grid>

        <!-- 第五行：进度和统计信息 -->
        <Border Grid.Row="4" Background="#E8F4F8" CornerRadius="5" Padding="10">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <TextBlock Text="{Binding ProgressText}" FontSize="12"/>
                    <TextBlock Text="共 {Binding MovieCount} 条" FontSize="12"/>
                </StackPanel>
                <ProgressBar Height="15" Value="{Binding ProgressValue}" 
                             Minimum="0" Maximum="100"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>