<Window x:Class="HcControlDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HcControlDemo"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">


    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧菜单 -->
        <TextBlock>ssss</TextBlock>
        
        <TreeView ItemsSource="{Binding Menus}">
            
            <TreeView.ItemTemplate>

                <HierarchicalDataTemplate ItemsSource="{Binding Children}">

                    <!-- 一级菜单 -->
                    <TextBlock Text="{Binding Title}" FontSize="14"/>

                    <HierarchicalDataTemplate.ItemTemplate>

                        <!-- 二级菜单 -->
                        <DataTemplate>

                            <Button Content="{Binding Title}"
                                    Padding="5"
                                    HorizontalAlignment="Left"
                                    Command="{Binding DataContext.NavigateCommand,
                                    RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding PageKey}"/>

                        </DataTemplate>

                    </HierarchicalDataTemplate.ItemTemplate>

                </HierarchicalDataTemplate>

            </TreeView.ItemTemplate>

        </TreeView>

        <!-- 右侧页面 -->
        <ContentControl
            Grid.Column="1"
            Content="{Binding CurrentView}"/>

    </Grid>
</Window>
